      function userRegister() {

      clearModalErrors();

      const email = document.getElementById('user-email-input').value.trim().toLowerCase();

      const name = document.getElementById('user-name-input').value.trim();

      if (!name) { showError('user-name-err', 'Por favor, insira seu nome.'); return; }

      if (name.length < 2) { showError('user-name-err', 'Nome muito curto.'); return; }

      const users = getUsers();

      if (users[email]) {

      showError('user-name-err', 'Este email já está cadastrado. Recarregue a página.');

      return;}

      users[email] = { name, registeredAt: Date.now() };

      setUsers(users);

      currentUser = { email, name, role: 'user' };

      saveSession(currentUser);

      closeModal('modal-user');

      enterApp();

      toast('🌸 Bem-vindo ao jardim, ' + name + '!');

      document.getElementById('user-step-email').style.display = 'block';

      document.getElementById('user-step-name').style.display = 'none';

